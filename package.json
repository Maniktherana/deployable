{
  "name": "deployable",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tooling"
    ],
    "catalog": {
      "@types/node": "^24.10.13",
      "effect": "4.0.0-beta.45",
      "typescript": "5.9.2",
      "vite": "^8.0.0",
      "vitest": "^3.0.5"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "oxlint --report-unused-disable-directives",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "oxfmt": "^0.40.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11"
}
